{
  "name": "Frihet | Shopify Order → Create Invoice",
  "nodes": [
    {
      "parameters": {
        "topic": "orders/create",
        "options": {}
      },
      "id": "f6a7b8c9-0006-4000-8000-000000000001",
      "name": "Shopify: Order Created",
      "type": "n8n-nodes-base.shopifyTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "credentials": {
        "shopifyApi": {
          "id": "3",
          "name": "Shopify API"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "field-001",
              "name": "customerName",
              "value": "={{ ($json.customer.first_name || '') + ' ' + ($json.customer.last_name || '') | trim || $json.billing_address.name || 'Shopify Customer' }}",
              "type": "string"
            },
            {
              "id": "field-002",
              "name": "customerEmail",
              "value": "={{ $json.email || $json.customer.email || '' }}",
              "type": "string"
            },
            {
