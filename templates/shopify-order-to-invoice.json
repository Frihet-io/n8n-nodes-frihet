              "value": "={{ $json.customer.phone || $json.billing_address.phone || '' }}",
              "type": "string"
            },
            {
              "id": "field-004",
              "name": "shopifyOrderId",
              "value": "={{ $json.id }}",
              "type": "string"
            },
            {
              "id": "field-005",
              "name": "shopifyOrderNumber",
              "value": "={{ $json.order_number || $json.name }}",
              "type": "string"
            },
            {
              "id": "field-006",
              "name": "currency",
              "value": "={{ $json.currency }}",
              "type": "string"
            },
            {
              "id": "field-007",
              "name": "lineItems",
              "value": "={{ $json.line_items }}",
              "type": "array"
            },
            {
              "id": "field-008",
              "name": "shippingTotal",
              "value": "={{ parseFloat($json.total_shipping_price_set.shop_money.amount || '0') }}",
              "type": "number"
            },
            {
              "id": "field-009",
              "name": "billingCity",
              "value": "={{ $json.billing_address.city || '' }}",
              "type": "string"
            },
